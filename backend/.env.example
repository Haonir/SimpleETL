# SimpleETL Backend Environment Variables
# Copy to .env and adjust values for your setup.
# All have defaults — only set what you need to override.
#
# NOTE: ETL config (LLM model, chunk size, output format, etc.) is sent
# from the frontend in the job request body. These env vars are only for
# SERVER-SIDE infrastructure and caps.

# ── Server-Side Caps ────────────────────────────────────────────────
# Maximum allowed values. Client requests are clamped to these limits.
# If user requests LOWER value → user value is used.
# If user requests HIGHER value → capped to this limit.
# Set to 0 to disable cap (allow any value from client).
APP_MAX_WORKERS_LIMIT=1
APP_CHUNK_SIZE_LIMIT=10000

# ── Server ──────────────────────────────────────────────────────────
APP_SERVER_PORT=8000

# ── Auth (optional) ─────────────────────────────────────────────────
# If set, enables X-API-Key header authentication.
# APP_API_KEY=your-secret-key

# ── CORS ────────────────────────────────────────────────────────────
# Comma-separated allowed origins.
# Default: http://localhost:5173,http://localhost:8000
# CORS_ORIGINS=http://localhost:5173,http://localhost:8000
