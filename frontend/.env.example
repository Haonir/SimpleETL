# SimpleETL Frontend Environment Variables
# Copy to .env and adjust values for your setup.
# Vite injects these at build time into import.meta.env.*

# ── API Base URL ────────────────────────────────────────────────────
# REST API base URL. Leave empty for same-origin (production) or proxy (dev).
VITE_API_BASE_URL=http://localhost:8000

# ── WebSocket Base URL ──────────────────────────────────────────────
# WebSocket endpoint. Leave empty to auto-detect from location.host.
VITE_WS_BASE_URL=ws://localhost:8000
